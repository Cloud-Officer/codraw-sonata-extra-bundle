{
    "name": "codraw/sonata-extra-bundle",
    "description": "Extra features and integrations for Sonata Admin",
    "license": "MIT",
    "type": "symfony-bundle",
    "keywords": [
        "symfony",
        "sonata"
    ],
    "require": {
        "php": "^8.5",
        "codraw/dependency-injection": "^0.39",
        "doctrine/common": "^3.1",
        "doctrine/inflector": "^2.0",
        "doctrine/orm": "^3.6",
        "doctrine/persistence": "^2.2 || ^3.0",
        "psr/log": "^3",
        "sonata-project/admin-bundle": "^4.8",
        "sonata-project/doctrine-orm-admin-bundle": "^4.2",
        "symfony/browser-kit": "^6.4.0",
        "symfony/framework-bundle": "^6.4.0",
        "symfony/expression-language": "^6.4.0",
        "symfony/string": "^6.4.0",
        "twig/twig": "^3.3"
    },
    "require-dev": {
        "cweagans/composer-patches": "^1.7",
        "codraw/tester": "^0.39",
        "codraw/security": "^0.39",
        "phpunit/phpunit": "^11.3 || ^12.0",
        "symfony/notifier": "^6.4.0"
    },
    "suggest": {
        "phpdocumentor/reflection-docblock": "Required to use the auto_help feature (^5.2)",
        "sonata-project/exporter": "Required to use the export feature of the admin controllers",
        "symfony/notifier": "Required to use the notifier feature and execution notifications (^6.4.0)",
        "symfony/workflow": "Required to use the workflow feature (^6.4.0)"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Draw\\Bundle\\SonataExtraBundle\\": ""
        }
    },
    "config": {
        "allow-plugins": {
            "cweagans/composer-patches": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.39-dev"
        },
        "patches": {
            "sonata-project/admin-bundle": {
                "support for operator in ModelAutocompleteType": "https://github.com/DumitracheAdrian/SonataAdminBundle/commit/fcbe6fa405b3d7f8590a231c19baa4821fcc081f.patch"
            },
            "sonata-project/doctrine-orm-admin-bundle": {
                "Batch model delete check": "https://github.com/mpoiriert/SonataDoctrineORMAdminBundle/commit/04f8a0e301bf09a1272b8f9d8535829ca870fb08.patch"
            }
        }
    },
    "replace": {
        "draw/sonata-extra-bundle": "self.version"
    }
}
